# Public URL of the deployed frontend (used for CORS + password reset links)
# e.g. https://collabspace-ai.vercel.app
CLIENT_URL=http://localhost:5173

# ================= Database =================
# Postgres connection string from Render (or your local Postgres for dev)
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ================= Auth =================
# Any long, random string — used to sign JWTs
JWT_SECRET="collabspace_secret"

